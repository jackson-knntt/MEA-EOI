# Copy this file to `.env.local` and fill in real values for local testing.
# `.env.local` is gitignored and must NEVER be committed (this repo is public).
# The same values must also be set as Environment Variables in Vercel for production.

# Notion integration secret (shared with ALL databases below)
NOTION_TOKEN=

# EOI "MEA EOI Submissions" database — used by BOTH of these (same ID in both):
NOTION_DATABASE_ID=
NOTION_EOI_DATABASE_ID=

# Corporate (£2,500) membership database
NOTION_MEMBERSHIP_DATABASE_ID=

# Sole Trader (£500) membership database  <-- NEW
NOTION_SOLE_TRADER_DATABASE_ID=

# YPG (Free) membership database  <-- NEW
NOTION_YPG_DATABASE_ID=
